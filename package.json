{
  "name": "skald",
  "version": "0.5.0",
  "description": "AI voice narrator for repo activity. Polls GitHub or GitLab feeds and tells the story.",
  "module": "src/index.ts",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "skald": "src/index.ts"
  },
  "license": "MIT",
  "author": "Ale Bles",
  "keywords": [
    "cli",
    "github",
    "gitlab",
    "narrator",
    "tts",
    "ai",
    "voice",
    "ink",
    "bun",
    "atom"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "lint": "bunx biome check src/",
    "lint:fix": "bunx biome check --fix src/",
    "format": "bunx biome format --write src/",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "yaml": "^2.8.3"
  }
}
